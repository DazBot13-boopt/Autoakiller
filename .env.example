# ── CTF Platform ─────────────────────────────────────────────────────────────
# Point at any CTF site — auto-detection handles CTFd, HTB, rCTF, picoCTF, etc.
CTF_URL=https://ctf.example.com
CTF_USER=yourteam
CTF_PASS=yourpassword
CTF_TOKEN=              # Optional: API token (overrides user/pass if set)

# ── Legacy CTFd aliases (backward-compat) ────────────────────────────────────
# CTFD_URL=https://ctf.example.com
# CTFD_TOKEN=ctfd_your_api_token_here

# ── API keys (OPTIONAL) ───────────────────────────────────────────────────────
# Not needed when using the default claude + codex CLI providers.
# Only fill these in if you want to use API-backed fallback providers.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=
